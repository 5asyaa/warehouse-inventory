                        </a>
                    </li>
                <% } else if (user.role === 'Admin') { %>
                    <li class="nav-item">
                        <a class="nav-link <%= activeMenu === 'peminjaman' ? 'active' : '' %>" href="/peminjaman/manage">
                            <i class="bi bi-book me-2"></i>Kelola Peminjaman
                        </a>
                    </li>
                <% } %>
            </ul>
            <ul class="navbar-nav ms-auto align-items-center gap-3">
