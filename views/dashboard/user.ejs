<div class="d-flex justify-content-between align-items-center mb-5 fade-in">
    <div>
        <h2 class="mb-1">Dashboard User</h2>
        <p class="text-muted mb-0">Selamat datang, <%= user.namaLengkap %>!</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon primary">
                    <i class="bi bi-box-arrow-right"></i>
                </div>
                <div class="stat-content">
                    <h5>Peminjaman Aktif</h5>
                    <p class="stat-value"><%= stats.peminjamanAktif %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon info">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="stat-content">
                    <h5>Riwayat Peminjaman</h5>
                    <p class="stat-value"><%= stats.riwayatPeminjaman %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon success">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div class="stat-content">
                    <h5>Barang Tersedia</h5>
                    <p class="stat-value"><%= stats.barangTersedia %></p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card mb-3 fade-in">
            <div class="card-header">
                <h5 class="card-title mb-0">Peminjaman Terbaru</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Kode</th>
                                <th>Barang</th>
                                <th>Jumlah</th>
                                <th>Tanggal Pinjam</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (recentPeminjaman && recentPeminjaman.length > 0) { %>
                                <% recentPeminjaman.slice(0, 5).forEach((item) => { %>
                                    <tr>
                                        <td><%= item.kode_peminjaman || '#' + item.id %></td>
                                        <td><%= item.nama_barang %></td>
                                        <td><%= item.jumlah %></td>
                                        <td><%= formatDate(item.tanggal_pinjam) %></td>
                                        <td>
                                            <% if (item.status === 'Menunggu') { %>
                                                <span class="badge bg-warning">Menunggu</span>
                                            <% } else if (item.status === 'Disetujui') { %>
                                                <span class="badge bg-success">Disetujui</span>
                                            <% } else if (item.status === 'Ditolak') { %>
                                                <span class="badge bg-danger">Ditolak</span>
                                            <% } else if (item.status === 'Dipinjam') { %>
                                                <span class="badge bg-primary">Dipinjam</span>
                                            <% } else if (item.status === 'Dikembalikan') { %>
                                                <span class="badge bg-secondary">Dikembalikan</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center text-muted">Belum ada peminjaman</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
