<div class="d-flex justify-content-between align-items-center mb-5 fade-in">
    <div>
        <h2 class="mb-1">Dashboard Admin</h2>
        <p class="text-muted mb-0">Selamat datang, <%= user.namaLengkap %>!</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon primary">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div class="stat-content">
                    <h5>Total Barang</h5>
                    <p class="stat-value"><%= stats.totalBarang %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon success">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div class="stat-content">
                    <h5>Barang Aktif</h5>
                    <p class="stat-value"><%= stats.barangAktif %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon danger">
                    <i class="bi bi-x-circle"></i>
                </div>
                <div class="stat-content">
                    <h5>Barang Nonaktif</h5>
                    <p class="stat-value"><%= stats.barangNonaktif %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon info">
                    <i class="bi bi-people"></i>
                </div>
                <div class="stat-content">
                    <h5>Total User</h5>
                    <p class="stat-value"><%= stats.totalUser %></p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon success">
                    <i class="bi bi-person-check"></i>
                </div>
                <div class="stat-content">
                    <h5>User Aktif</h5>
                    <p class="stat-value"><%= stats.userAktif %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon warning">
                    <i class="bi bi-tags"></i>
                </div>
                <div class="stat-content">
                    <h5>Total Kategori</h5>
                    <p class="stat-value"><%= stats.totalKategori %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon secondary">
                    <i class="bi bi-geo-alt"></i>
                </div>
                <div class="stat-content">
                    <h5>Total Lokasi</h5>
                    <p class="stat-value"><%= stats.totalLokasi %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon primary">
                    <i class="bi bi-book"></i>
                </div>
                <div class="stat-content">
                    <h5>Total Peminjaman</h5>
                    <p class="stat-value"><%= stats.totalPeminjaman %></p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon warning">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="stat-content">
                    <h5>Pending Approval</h5>
                    <p class="stat-value"><%= stats.pendingApproval %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon info">
                    <i class="bi bi-box-arrow-right"></i>
                </div>
                <div class="stat-content">
                    <h5>Barang Dipinjam</h5>
                    <p class="stat-value"><%= stats.barangDipinjam %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3 fade-in">
            <div class="card-body stat-card">
                <div class="stat-icon danger">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div class="stat-content">
                    <h5>Barang Terlambat</h5>
                    <p class="stat-value"><%= stats.overdue %></p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card mb-3 fade-in">
            <div class="card-header">
                <h5 class="card-title mb-0">Peminjaman per Bulan</h5>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="monthlyChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3 fade-in">
            <div class="card-header">
                <h5 class="card-title mb-0">Status Peminjaman</h5>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card mb-3 fade-in">
            <div class="card-header">
                <h5 class="card-title mb-0">Barang berdasarkan Kategori</h5>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="kategoriChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log('Chart data:', <%- JSON.stringify(chartData) %>);

    // Monthly Chart
    const monthlyCanvas = document.getElementById('monthlyChart');
    if (monthlyCanvas) {
        const monthlyLabels = <%- JSON.stringify(chartData.monthly.map(m => m.month)) %>;
        const monthlyData = <%- JSON.stringify(chartData.monthly.map(m => m.count)) %>;
        
        console.log('Monthly labels:', monthlyLabels);
        console.log('Monthly data:', monthlyData);

        new Chart(monthlyCanvas.getContext('2d'), {
            type: 'line',
            data: {
                labels: monthlyLabels,
                datasets: [{
                    label: 'Jumlah Peminjaman',
                    data: monthlyData,
                    borderColor: 'rgb(75, 192, 192)',
                    backgroundColor: 'rgba(75, 192, 192, 0.2)',
                    tension: 0.1,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                }
            }
        });
    }

    // Status Chart
    const statusCanvas = document.getElementById('statusChart');
    if (statusCanvas) {
        const statusLabels = <%- JSON.stringify(chartData.status.map(s => s.status)) %>;
        const statusData = <%- JSON.stringify(chartData.status.map(s => s.count)) %>;
        const statusColors = {
            'Menunggu': 'rgba(255, 193, 7, 0.8)',
            'Disetujui': 'rgba(25, 135, 84, 0.8)',
            'Ditolak': 'rgba(220, 53, 69, 0.8)',
            'Dipinjam': 'rgba(13, 110, 253, 0.8)',
            'Dikembalikan': 'rgba(108, 117, 125, 0.8)'
        };
        
        console.log('Status labels:', statusLabels);
        console.log('Status data:', statusData);

        new Chart(statusCanvas.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: statusLabels,
                datasets: [{
                    data: statusData,
                    backgroundColor: statusLabels.map(label => statusColors[label] || 'rgba(0, 0, 0, 0.8)')
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false
            }
        });
    }

    // Kategori Chart
    const kategoriCanvas = document.getElementById('kategoriChart');
    if (kategoriCanvas) {
        const kategoriLabels = <%- JSON.stringify(chartData.kategori.map(k => k.nama_kategori)) %>;
        const kategoriData = <%- JSON.stringify(chartData.kategori.map(k => k.count)) %>;
        
        console.log('Kategori labels:', kategoriLabels);
        console.log('Kategori data:', kategoriData);

        new Chart(kategoriCanvas.getContext('2d'), {
            type: 'bar',
            data: {
                labels: kategoriLabels,
                datasets: [{
                    label: 'Jumlah Barang',
                    data: kategoriData,
                    backgroundColor: 'rgba(54, 162, 235, 0.8)',
                    borderColor: 'rgba(54, 162, 235, 1)',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                }
            }
        });
    }
});
</script>
