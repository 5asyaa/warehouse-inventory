<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Daftar User</h2>
    <a href="/user/create" class="btn btn-primary">
        <i class="bi bi-plus"></i> Tambah User
    </a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger">
        <%= error %>
    </div>
<% } %>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="userTable" class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Nama</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach((usr, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= usr.nama_lengkap %></td>
                            <td><%= usr.username %></td>
                            <td><%= usr.email %></td>
                            <td>
                                <% if (usr.role === 'Admin') { %>
                                    <span class="badge bg-danger">Admin</span>
                                <% } else { %>
                                    <span class="badge bg-primary">User</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (usr.status === 'Aktif') { %>
                                    <span class="badge bg-success">Aktif</span>
                                <% } else { %>
                                    <span class="badge bg-secondary">Nonaktif</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/user/<%= usr.id %>/edit" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <% if (usr.status === 'Aktif') { %>
                                    <button onclick="deactivateUser(<%= usr.id %>, '<%= usr.nama_lengkap %>')" class="btn btn-sm btn-secondary">
                                        <i class="bi bi-person-x"></i> Nonaktifkan
                                    </button>
                                <% } else { %>
                                    <button onclick="activateUser(<%= usr.id %>, '<%= usr.nama_lengkap %>')" class="btn btn-sm btn-success">
                                        <i class="bi bi-person-check"></i> Aktifkan
                                    </button>
                                <% } %>
                                <% if (!usr.hasPeminjamanRelations) { %>
                                    <button onclick="deleteUser(<%= usr.id %>, '<%= usr.nama_lengkap %>')" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Hapus
                                    </button>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
$(document).ready(function() {
    $('#userTable').DataTable({
        language: {
            url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/id.json'
        },
        order: [[1, 'asc']]
    });
});

function deactivateUser(id, nama) {
    Swal.fire({
        title: '⚠ Nonaktifkan User',
        text: `User tidak dapat login, namun data tetap tersimpan.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f59e0b',
        cancelButtonColor: '#6b7280',
        confirmButtonText: 'Nonaktifkan',
        cancelButtonText: 'Batalkan'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch(`/user/${id}/deactivate`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Berhasil',
                        text: data.message,
                        icon: 'success'
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        title: 'Gagal',
                        text: data.message,
                        icon: 'error'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    title: 'Error',
                    text: 'Terjadi kesalahan. Silakan coba lagi.',
                    icon: 'error'
                });
            });
        }
    });
}

function activateUser(id, nama) {
    Swal.fire({
        title: '⚠ Aktifkan User',
        text: `User akan dapat login kembali.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f59e0b',
        cancelButtonColor: '#6b7280',
        confirmButtonText: 'Aktifkan',
        cancelButtonText: 'Batalkan'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch(`/user/${id}/activate`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Berhasil',
                        text: data.message,
                        icon: 'success'
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        title: 'Gagal',
                        text: data.message,
                        icon: 'error'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    title: 'Error',
                    text: 'Terjadi kesalahan. Silakan coba lagi.',
                    icon: 'error'
                });
            });
        }
    });
}

function deleteUser(id, nama) {
    Swal.fire({
        title: '⚠ Hapus Permanen',
        text: `Data akan dihapus secara permanen. Riwayat tidak dapat dikembalikan.`,
        icon: 'error',
        showCancelButton: true,
        confirmButtonColor: '#dc2626',
        cancelButtonColor: '#6b7280',
        confirmButtonText: 'Hapus Permanen',
        cancelButtonText: 'Batalkan'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch(`/user/${id}/delete`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Berhasil',
                        text: data.message,
                        icon: 'success'
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        title: 'Gagal',
                        text: data.message,
                        icon: 'error'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    title: 'Error',
                    text: 'Terjadi kesalahan. Silakan coba lagi.',
                    icon: 'error'
                });
            });
        }
    });
}
</script>
