<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Daftar Barang</h2>
    <a href="/barang/create" class="btn btn-primary">
        <i class="bi bi-plus"></i> Tambah Barang
    </a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger">
        <%= error %>
    </div>
<% } %>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="barangTable" class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Foto</th>
                        <th>Kode</th>
                        <th>Nama Barang</th>
                        <th>Kategori</th>
                        <th>Lokasi</th>
                        <th>Stok</th>
                        <th>Kondisi</th>
                        <th>Status</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% barang.forEach((item) => { %>
                        <tr>
                            <td>
                                <img src="<%= item.foto %>" alt="<%= item.nama_barang %>" 
                                     class="img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;">
                            </td>
                            <td><%= item.kode_barang %></td>
                            <td>
                                <a href="/barang/<%= item.id %>"><%= item.nama_barang %></a>
                            </td>
                            <td><%= item.nama_kategori || '-' %></td>
                            <td><%= item.nama_lokasi || '-' %></td>
                            <td>
                                <%= item.stok %>
                                <% if (item.stok <= item.stok_minimum) { %>
                                    <span class="badge bg-warning text-dark ms-1">Hampir Habis</span>
                                <% } %>
                            </td>
                            <td><%= item.kondisi %></td>
                            <td>
                                <% if (item.status === 'Aktif') { %>
                                    <span class="badge bg-success">Aktif</span>
                                <% } else { %>
                                    <span class="badge bg-danger">Nonaktif</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/barang/<%= item.id %>" class="btn btn-sm btn-info" title="Detail">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="/barang/<%= item.id %>/edit" class="btn btn-sm btn-warning" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <% if (item.status === 'Aktif') { %>
                                    <button onclick="deactivateBarang(<%= item.id %>, '<%= item.nama_barang %>')" class="btn btn-sm btn-secondary" title="Nonaktifkan">
                                        <i class="bi bi-dash-circle"></i>
                                    </button>
                                <% } else { %>
                                    <button onclick="activateBarang(<%= item.id %>, '<%= item.nama_barang %>')" class="btn btn-sm btn-success" title="Aktifkan">
                                        <i class="bi bi-check-circle"></i>
                                    </button>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
$(document).ready(function() {
    $('#barangTable').DataTable({
        language: {
            url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/id.json'
        },
        order: [[1, 'asc']]
    });
});

function deactivateBarang(id, nama) {
    Swal.fire({
        title: '⚠ Nonaktifkan Barang',
        text: `Barang tidak akan tersedia untuk transaksi, namun data tetap tersimpan.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f59e0b',
        cancelButtonColor: '#6b7280',
        confirmButtonText: 'Nonaktifkan',
        cancelButtonText: 'Batalkan'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch(`/barang/${id}/delete`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Berhasil',
                        text: data.message,
                        icon: 'success'
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        title: 'Gagal',
                        text: data.message,
                        icon: 'error'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    title: 'Error',
                    text: 'Terjadi kesalahan. Silakan coba lagi.',
                    icon: 'error'
                });
            });
        }
    });
}

function activateBarang(id, nama) {
    Swal.fire({
        title: '⚠ Aktifkan Barang',
        text: `Barang akan tersedia kembali untuk transaksi.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f59e0b',
        cancelButtonColor: '#6b7280',
        confirmButtonText: 'Aktifkan',
        cancelButtonText: 'Batalkan'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch(`/barang/${id}/activate`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Berhasil',
                        text: data.message,
                        icon: 'success'
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        title: 'Gagal',
                        text: data.message,
                        icon: 'error'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    title: 'Error',
                    text: 'Terjadi kesalahan. Silakan coba lagi.',
                    icon: 'error'
                });
            });
        }
    });
}
</script>
