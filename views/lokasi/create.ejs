<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Tambah Lokasi</h2>
    <a href="/lokasi" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Kembali
    </a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger">
        <%= error %>
    </div>
<% } %>

<div class="card">
    <div class="card-body">
        <form action="/lokasi" method="POST">
            <div class="mb-3">
                <label for="nama_lokasi" class="form-label">Nama Lokasi <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="nama_lokasi" name="nama_lokasi" 
                       value="<%= typeof nama_lokasi !== 'undefined' ? nama_lokasi : '' %>" required maxlength="100">
                <small class="text-muted">Maksimal 100 karakter</small>
            </div>

            <div class="mb-3">
                <label for="deskripsi" class="form-label">Deskripsi</label>
                <textarea class="form-control" id="deskripsi" name="deskripsi" rows="3" maxlength="255"><%= typeof deskripsi !== 'undefined' ? deskripsi : '' %></textarea>
                <small class="text-muted">Maksimal 255 karakter</small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Simpan
                </button>
                <a href="/lokasi" class="btn btn-secondary">
                    <i class="bi bi-x"></i> Batal
                </a>
            </div>
        </form>
    </div>
</div>
