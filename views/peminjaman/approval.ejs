<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Kelola Peminjaman</h2>
</div>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger">
        <%= error %>
    </div>
<% } %>

<% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success">
        <%= success %>
    </div>
<% } %>

<div class="card shadow">
    <div class="card-body">
        <div class="table-responsive">
            <table id="peminjamanTable" class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Kode</th>
                        <th>Nama User</th>
                        <th>Barang</th>
                        <th>Jumlah</th>
                        <th>Tanggal Pinjam</th>
                        <th>Tanggal Kembali</th>
                        <th>Status</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% peminjaman.forEach((item, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= item.kode_peminjaman || '#' + item.id %></td>
                            <td><%= item.nama_user %></td>
                            <td>
                                <%= item.nama_barang %>
                                <br>
                                <small class="text-muted"><%= item.kode_barang %></small>
                            </td>
                            <td><%= item.jumlah %></td>
                            <td><%= item.tanggal_pinjam || '-' %></td>
                            <td><%= item.tanggal_jatuh_tempo %></td>
                            <td>
                                <% if (item.status === 'Menunggu') { %>
                                    <span class="badge bg-warning text-dark">Menunggu</span>
                                <% } else if (item.status === 'Disetujui') { %>
                                    <span class="badge bg-success">Disetujui</span>
                                <% } else if (item.status === 'Ditolak') { %>
                                    <span class="badge bg-danger">Ditolak</span>
                                <% } else if (item.status === 'Dipinjam') { %>
                                    <span class="badge bg-primary">Dipinjam</span>
                                <% } else if (item.status === 'Dikembalikan') { %>
                                    <span class="badge bg-secondary">Dikembalikan</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="/peminjaman/manage/<%= item.id %>" class="btn btn-info" title="Detail">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <% if (item.status === 'Menunggu') { %>
                                        <button onclick="approvePeminjaman(<%= item.id %>)" class="btn btn-success" title="Setujui">
                                            <i class="bi bi-check"></i>
                                        </button>
                                        <button onclick="showRejectModal(<%= item.id %>)" class="btn btn-danger" title="Tolak">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    <% } %>
                                    <% if (item.status === 'Disetujui' || item.status === 'Dipinjam') { %>
                                        <button onclick="returnPeminjaman(<%= item.id %>)" class="btn btn-warning" title="Kembalikan">
                                            <i class="bi bi-arrow-return-left"></i>
                                        </button>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tolak Peminjaman</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="rejectForm">
                    <input type="hidden" id="rejectPeminjamanId" name="id">
                    <div class="mb-3">
                        <label for="alasan_penolakan" class="form-label">Alasan Penolakan</label>
                        <textarea class="form-control" id="alasan_penolakan" name="alasan_penolakan" rows="4" required></textarea>
                        <div class="form-text">Alasan penolakan wajib diisi.</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" onclick="submitReject()" class="btn btn-danger">Tolak</button>
            </div>
        </div>
    </div>
</div>

<script>
$(document).ready(function() {
    $('#peminjamanTable').DataTable({
        language: {
            url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/id.json'
        },
        order: [[1, 'desc']]
    });
});

function approvePeminjaman(id) {
    Swal.fire({
        title: 'Setujui Peminjaman?',
        text: 'Stok barang akan dikurangi secara otomatis.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Ya, Setujui',
        cancelButtonText: 'Batal'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch(`/peminjaman/manage/${id}/approve`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire('Berhasil', 'Peminjaman telah disetujui.', 'success')
                        .then(() => location.reload());
                } else {
                    Swal.fire('Gagal', data.message || 'Terjadi kesalahan.', 'error');
                }
            })
            .catch(error => {
                Swal.fire('Gagal', 'Terjadi kesalahan.', 'error');
            });
        }
    });
}

function showRejectModal(id) {
    $('#rejectPeminjamanId').val(id);
    $('#alasan_penolakan').val('');
    const modal = new bootstrap.Modal(document.getElementById('rejectModal'));
    modal.show();
}

function submitReject() {
    const id = $('#rejectPeminjamanId').val();
    const alasan = $('#alasan_penolakan').val();

    if (!alasan || alasan.trim().length < 5) {
        Swal.fire('Gagal', 'Alasan penolakan wajib diisi minimal 5 karakter.', 'error');
        return;
    }

    fetch(`/peminjaman/manage/${id}/reject`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ alasan_penolakan: alasan })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            Swal.fire('Berhasil', 'Peminjaman telah ditolak.', 'success')
                .then(() => location.reload());
        } else {
            Swal.fire('Gagal', data.message || 'Terjadi kesalahan.', 'error');
        }
    })
    .catch(error => {
        Swal.fire('Gagal', 'Terjadi kesalahan.', 'error');
    });
}

function returnPeminjaman(id) {
    Swal.fire({
        title: 'Kembalikan Barang?',
        text: 'Stok barang akan dikembalikan secara otomatis.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Ya, Kembalikan',
        cancelButtonText: 'Batal'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch(`/peminjaman/manage/${id}/return`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire('Berhasil', 'Barang telah dikembalikan.', 'success')
                        .then(() => location.reload());
                } else {
                    Swal.fire('Gagal', data.message || 'Terjadi kesalahan.', 'error');
                }
            })
            .catch(error => {
                Swal.fire('Gagal', 'Terjadi kesalahan.', 'error');
            });
        }
    });
}
</script>
